def load_preset(path, requested_tools=None):
    """Loads tools and system instructions from a preset file."""
    if not os.path.exists(path):
        print(f"Error: Preset file not found: {path}", file=sys.stderr)
        return [], ""
    
    spec = importlib.util.spec_from_file_location("preset", path)
    module = importlib.util.module_from_spec(spec)
    try:
        spec.loader.exec_module(module)
    except Exception as e:
        print(f"Error loading preset: {e}", file=sys.stderr)
        return [], ""
    
    all_tools = getattr(module, "tools", [])
    all_sets = getattr(module, "tool_sets", {})
    system_instruction = getattr(module, "system_instruction", "")

    if not requested_tools:
        return all_tools, system_instruction

    selected_tools = []
    tool_map = {t.__name__: t for t in all_tools}
    
    names = [n.strip() for n in requested_tools.split(",")]
    for name in names:
        if name in all_sets:
            selected_tools.extend(all_sets[name])
        elif name in tool_map:
            selected_tools.append(tool_map[name])
        else:
            print(f"Warning: Tool or set '{name}' not found in {path}", file=sys.stderr)

    seen = set()
    unique_tools = []
    for t in selected_tools:
        if t not in seen:
            unique_tools.append(t)
            seen.add(t)

    return unique_tools, system_instruction

def _resolve_litertlm_in_dir(d):
    """If `d` is a litert-lm registry model dir, return the .litertlm file inside.

    The litert-lm CLI (`litert-lm import SOURCE MODEL_ID`) stores imported models
    as `<storage>/<model-id>/model.litertlm`, so a shorthand like `qwen3-4b`
    resolves to a directory. The Engine needs the .litertlm *file*, not the dir.
    Prefer `model.litertlm`; otherwise fall back to the first .litertlm found.
    Returns None if `d` is not a directory or holds no .litertlm.
    """
    if not os.path.isdir(d):
        return None
    preferred = os.path.join(d, "model.litertlm")
    if os.path.isfile(preferred):
        return preferred
    try:
        for child in sorted(os.listdir(d)):
            if child.endswith(".litertlm") and os.path.isfile(os.path.join(d, child)):
                return os.path.join(d, child)
    except OSError:
        pass
    return None

def resolve_model_path(model_ref):
    """Resolves model reference to an absolute path."""
    if os.path.exists(model_ref):
        ref = os.path.abspath(model_ref)
        return _resolve_litertlm_in_dir(ref) or ref

    storage_paths = [
        os.path.expanduser("~/.litert-lm/models"),
        os.path.expanduser("~/.config/litert-lm/models"),
    ]

    env_path = os.getenv("LITERT_LM_MODELS_DIR")
    if env_path:
        storage_paths.insert(0, os.path.expanduser(env_path))

    for base in storage_paths:
        target = os.path.join(base, model_ref)
        if os.path.exists(target):
            return _resolve_litertlm_in_dir(target) or target
        if not target.endswith(".litertlm"):
            target_ext = target + ".litertlm"
            if os.path.exists(target_ext):
                return target_ext

    return model_ref

def get_available_models():
    """Returns a list of available models by scanning LiteRT-LM storage paths.

    A model is either a `.litertlm` file in a storage path, or a subdirectory
    that itself contains a `.litertlm` file. CWD is intentionally excluded —
    it caused the server to surface filesystem root entries when launched from /.
    """
    storage_paths = [
        os.path.expanduser("~/.litert-lm/models"),
        os.path.expanduser("~/.config/litert-lm/models"),
    ]
    env_path = os.getenv("LITERT_LM_MODELS_DIR")
    if env_path:
        storage_paths.insert(0, os.path.expanduser(env_path))

    models = set(["gemma-4-E2B-it", "gemma-4-E4B-it"])
    for base in storage_paths:
        if not os.path.isdir(base):
            continue
        try:
            for item in os.listdir(base):
                if item.startswith("."):
                    continue
                full = os.path.join(base, item)
                if os.path.isfile(full) and item.endswith(".litertlm"):
                    models.add(item[:-len(".litertlm")])
                elif os.path.isdir(full):
                    try:
                        if any(child.endswith(".litertlm") for child in os.listdir(full)):
                            models.add(item)
                    except Exception:
                        continue
        except Exception:
            continue
    return sorted(list(models))

def _peek_model(model_path):
    """Run litert-lm-peek on a .litertlm bundle and return parsed metadata.

    Returns {"version": str|None, "types": set[str], "constraints": dict[str,str]}
    or None if the path isn't a readable .litertlm or peek is unavailable/errors.
    `types` holds the bundle's `model_type` strings (e.g. tf_lite_vision_encoder,
    tf_lite_audio_encoder_hw, tf_lite_mtp_drafter); `constraints` maps a type to
    its declared backend_constraint when present. peek is a metadata-only read
    (~0.1s even on multi-GB bundles), so this is cheap to call before Engine init.
    """
    if not (model_path.endswith(".litertlm") and os.path.isfile(model_path)):
        return None
    peek = os.path.join(os.path.dirname(sys.executable), "litert-lm-peek")
    if not os.path.isfile(peek):
        return None
    import subprocess
    try:
        out = subprocess.run(
            [peek, "--litertlm_file", model_path],
            capture_output=True, text=True, timeout=20,
        ).stdout
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        return None
    info = {"version": None, "types": set(), "constraints": {}}
    last_type = None
    for line in out.splitlines():
        s = line.strip()
        if s.startswith("LiteRT-LM Version:"):
            info["version"] = s.split(":", 1)[1].strip()
        elif "model_type, Value (String):" in s:
            t = s.split("model_type, Value (String):", 1)[1].strip()
            info["types"].add(t)
            last_type = t
        elif "backend_constraint, Value (String):" in s and last_type:
            info["constraints"][last_type] = s.split("backend_constraint, Value (String):", 1)[1].strip()
    return info

def detect_model_capabilities(model_path):
    """Report which encoders/heads a .litertlm bundle contains.

    Returns {"vision": bool, "audio": bool, "mtp": bool}. The LiteRT-LM runtime
    raises NOT_FOUND at conversation creation if a vision/audio backend is wired
    up for a bundle lacking that encoder (e.g. an imported text-only Qwen3), and
    Engine init fails if speculative decoding is requested with no MTP draft head.
    Best-effort: if peek is missing/errors or prints no model_type lines, assume
    full multimodal so behavior is unchanged for the Gemma 4 bundles.
    """
    caps = {"vision": True, "audio": True, "mtp": True}
    info = _peek_model(model_path)
    if info and info["types"]:
        caps["vision"] = "tf_lite_vision_encoder" in info["types"]
        caps["audio"] = "tf_lite_audio_encoder_hw" in info["types"]
        caps["mtp"] = "tf_lite_mtp_drafter" in info["types"]
    return caps

def print_model_info(model_ref):
    """Print a capability/metadata summary for `gbox modelinfo <model>`.

    Returns a process exit code (0 ok, 1 if the model can't be resolved).
    """
    path = resolve_model_path(model_ref)
    if not (path.endswith(".litertlm") and os.path.isfile(path)):
        print(f"Error: could not resolve '{model_ref}' to a .litertlm file.", file=sys.stderr)
        print("Check your model storage paths (run 'gbox --help' for search order).", file=sys.stderr)
        return 1

    def _human(n):
        for unit in ("B", "KB", "MB", "GB", "TB"):
            if n < 1024:
                return f"{n:.1f} {unit}"
            n /= 1024
        return f"{n:.1f} PB"

    print(f"Model:      {model_ref}")
    print(f"Path:       {path}")
    print(f"Size:       {_human(os.path.getsize(path))}")
    info = _peek_model(path)
    if not info:
        print("Metadata:   (litert-lm-peek unavailable — cannot read bundle sections)")
        return 0
    if info["version"]:
        print(f"Format:     LiteRT-LM {info['version']}")
    modalities = ["text"]
    if "tf_lite_vision_encoder" in info["types"]:
        modalities.append("vision")
    if "tf_lite_audio_encoder_hw" in info["types"]:
        modalities.append("audio")
    print(f"Modalities: {', '.join(modalities)}")
    print(f"MTP draft:  {'yes' if 'tf_lite_mtp_drafter' in info['types'] else 'no'}")
    if info["constraints"]:
        cons = ", ".join(f"{k.replace('tf_lite_', '')}={v}" for k, v in sorted(info["constraints"].items()))
        print(f"Backend constraints: {cons}")
    return 0

def resolve_fabric_resource(resource_type, name):
    """Resolves a named resource from the fabric directory."""
    if not name: return None
    
    # Absolute paths are returned as is
    if os.path.isabs(name) or name.startswith("./") or name.startswith("~"):
        return os.path.abspath(os.path.expanduser(name))
    
    search_paths = []
    if resource_type == "system-file":
        search_paths = [
            os.path.join(FABRIC_DIR, "patterns", name, "system.md"),
            os.path.join(FABRIC_DIR, "patterns", "ias", name, "system.md")
        ]
    elif resource_type == "context":
        search_paths = [
            os.path.join(FABRIC_DIR, "contexts", name),
            os.path.join(FABRIC_DIR, "contexts", name + ".md")
        ]
    elif resource_type == "schema":
        search_paths = [
            os.path.join(FABRIC_DIR, "schemas", name),
            os.path.join(FABRIC_DIR, "schemas", name + ".json")
        ]
    elif resource_type == "session":
        return os.path.join(FABRIC_DIR, "sessions", name + ".json")

    for path in search_paths:
        if os.path.exists(path):
            return path
    return None

def copy_to_clipboard(text):
    """Copies text to the macOS clipboard via pbcopy."""
    if not text:
        return
    import subprocess
    try:
        subprocess.run(["pbcopy"], input=text.encode("utf-8"), check=True)
        print("[Copied to clipboard]", file=sys.stderr)
    except FileNotFoundError:
        print("Warning: pbcopy not found (macOS only).", file=sys.stderr)
    except Exception as e:
        print(f"Warning: Failed to copy to clipboard: {e}", file=sys.stderr)

def process_pdf(pdf_bytes):
    """Processes PDF bytes and returns extracted text and a preview image path."""
    text = ""
    image_path = None
    try:
        import fitz  # PyMuPDF
        doc = fitz.open(stream=pdf_bytes, filetype="pdf")
        for page in doc:
            text += page.get_text() + "\n"
        if len(doc) > 0:
            page = doc[0]
            pix = page.get_pixmap()
            fd, path = tempfile.mkstemp(suffix=".png")
            with os.fdopen(fd, 'wb') as f:
                pix.save(path)
            image_path = path
    except ImportError:
        pass
    except Exception as e:
        print(f"Error processing PDF: {e}", file=sys.stderr)
    return text.strip(), image_path

def manage_session_window(messages, limit=3500):
    """Prunes and summarizes message history to stay within token limits."""
    # Rough estimation: 1 token ~= 4 characters for English
    total_chars = sum(len(json.dumps(m)) for m in messages)
    if total_chars < limit * 4:
        return messages

    print(f"[Session] Context window high ({total_chars // 4} tokens). Summarizing history...", file=sys.stderr)
    
    # Keep system message (usually index 0)
    system_msg = messages[0] if messages and messages[0].get("role") == "system" else None
    rest = messages[1:] if system_msg else messages
    
    # Keep the last 4 messages as "active"
    active_window = rest[-4:]
    to_summarize = rest[:-4]
    
    if not to_summarize:
        return messages

    summary_text = f"Summary of earlier conversation ({len(to_summarize)} messages): "
    summary_text += " ".join([m.get("content", "")[:100] for m in to_summarize if isinstance(m.get("content"), str)])
    
    new_messages = []
    if system_msg: new_messages.append(system_msg)
    new_messages.append({"role": "user", "content": f"[Automated Summary of Earlier Conversation]\n{summary_text}"})
    new_messages.append({"role": "assistant", "content": "I have noted the summary of our earlier context. How can I help you now?"})
    new_messages.extend(active_window)
    
    return new_messages

def run_server(args, engine, selected_model, tools, system_msg):
    from http.server import ThreadingHTTPServer, BaseHTTPRequestHandler
    import json
    import time
    import uuid

    class InferenceHandler(BaseHTTPRequestHandler):
        def do_GET(self):
            if self.path in ("/models", "/v1/models"):
                models = get_available_models()
                data = {
                    "object": "list",
                    "data": [
                        {"id": m, "object": "model", "created": 1686935002, "owned_by": "gbox"}
                        for m in models
                    ]
                }
                resp_json = json.dumps(data).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(resp_json)))
                self.end_headers()
                self.wfile.write(resp_json)
            elif self.path == "/config":
                data = {
                    "model": selected_model,
                    "tools": [t.__name__ for t in tools],
                    "max_tokens": args.max_tokens,
                    "enable_speculative_decoding": bool(getattr(args, "_mtp_resolved", False)),
                    "backend": args.backend,
                    "vision_backend": args.vision_backend,
                    "audio_backend": args.audio_backend,
                }
                resp_json = json.dumps(data).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(resp_json)))
                self.end_headers()
                self.wfile.write(resp_json)
            else:
                self.send_response(404)
                self.end_headers()
                self.wfile.write(b"Not Found")

        def do_POST(self):
            if self.path in ("/", "/infer", "/v1/chat/completions"):
                content_length = int(self.headers.get("Content-Length", 0))
                post_data = self.rfile.read(content_length)
                try:
                    req_data = json.loads(post_data)
                except Exception:
                    self.send_response(400)
                    self.end_headers()
                    self.wfile.write(b"Invalid JSON")
                    return
                
                messages = req_data.get("messages", [])
                if not messages:
                    # Support for simple prompt field if messages missing
                    prompt = req_data.get("prompt")
                    if prompt:
                        messages = [{"role": "user", "content": prompt}]
                    else:
                        self.send_response(400)
                        self.end_headers()
                        self.wfile.write(b"No messages or prompt provided")
                        return
                
                context_msgs = messages[:-1] if len(messages) > 1 else []
                last_msg = messages[-1]
                
                final_context = []
                has_system = any(m.get("role") == "system" for m in messages)
                if system_msg and not has_system:
                    final_context.append({"role": "system", "content": [{"type": "text", "text": system_msg}]})
                
                for msg in context_msgs:
                    role = msg.get("role", "user")
                    content = msg.get("content", "")
                    if isinstance(content, str):
                        content = [{"type": "text", "text": content}]
                    final_context.append({"role": role, "content": content})
                
                user_content = last_msg.get("content", "")
                if isinstance(user_content, str):
                    user_content_list = [{"type": "text", "text": user_content}]
                else:
                    user_content_list = user_content
                
                message_obj = {"role": last_msg.get("role", "user"), "content": user_content_list}

                try:
                    is_stream = req_data.get("stream", False)
                    request_id = f"chatcmpl-{uuid.uuid4()}"
                    created_time = int(time.time())
                    model_name = req_data.get("model", args.model_or_prompt or "gbox-model")

                    with engine.create_conversation(tools=tools, messages=final_context) as conv:
                        if is_stream:
                            self.send_response(200)
                            self.send_header("Content-Type", "text/event-stream")
                            self.send_header("Cache-Control", "no-cache")
                            self.send_header("Connection", "keep-alive")
                            self.end_headers()
                            
                            stream = conv.send_message_async(message_obj)
                            for chunk in stream:
                                chunk_text = "".join([part.get("text", "") for part in chunk.get("content", []) if part.get("type") == "text"])
                                if not chunk_text: continue
                                
                                resp_chunk = {
                                    "id": request_id,
                                    "object": "chat.completion.chunk",
                                    "created": created_time,
                                    "model": model_name,
                                    "choices": [{
                                        "index": 0,
                                        "delta": {"content": chunk_text},
                                        "finish_reason": None
                                    }]
                                }
                                self.wfile.write(f"data: {json.dumps(resp_chunk)}\n\n".encode("utf-8"))
                                self.wfile.flush()
                            
                            final_resp_chunk = {
                                "id": request_id,
                                "object": "chat.completion.chunk",
                                "created": created_time,
                                "model": model_name,
                                "choices": [{
                                    "index": 0,
                                    "delta": {},
                                    "finish_reason": "stop"
                                }]
                            }
                            self.wfile.write(f"data: {json.dumps(final_resp_chunk)}\n\n".encode("utf-8"))
                            self.wfile.write(b"data: [DONE]\n\n")
                            self.wfile.flush()
                        else:
                            response = conv.send_message(message_obj)
                            raw_text = "".join([part.get("text", "") for part in response.get("content", []) if part.get("type") == "text"])
                            
                            resp_data = {
                                "id": request_id,
                                "object": "chat.completion",
                                "created": created_time,
                                "model": model_name,
                                "choices": [{
                                    "index": 0,
                                    "message": {"role": "assistant", "content": raw_text},
                                    "finish_reason": "stop"
                                }],
                                "usage": {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
                            }
                            
                            resp_json = json.dumps(resp_data).encode("utf-8")
                            self.send_response(200)
                            self.send_header("Content-Type", "application/json")
                            self.send_header("Content-Length", str(len(resp_json)))
                            self.end_headers()
                            self.wfile.write(resp_json)
                except Exception as e:
                    import traceback
                    tb = traceback.format_exc()
                    print(f"[500] {type(e).__name__}: {e}\n{tb}", file=sys.stderr, flush=True)
                    self.send_response(500)
                    self.send_header("Content-Type", "application/json")
                    self.end_headers()
                    self.wfile.write(json.dumps({"error": str(e), "type": type(e).__name__, "traceback": tb}).encode("utf-8"))
            else:
                self.send_response(404)
                self.end_headers()
                self.wfile.write(b"Not Found")

    if getattr(args, "_internal_run", False):
        server_dir = os.path.expanduser("~/.gbox")
        os.makedirs(server_dir, exist_ok=True)
        with open(os.path.join(server_dir, "server.pid"), "w") as f:
            f.write(str(os.getpid()))

    server = ThreadingHTTPServer(("0.0.0.0", args.port), InferenceHandler)
    mtp_state = "on" if getattr(args, "_mtp_resolved", False) else "off"
    print(f"Starting gbox inference server on http://0.0.0.0:{args.port}")
    print(f"Model: {selected_model} | backend: {args.backend} | MTP: {mtp_state} | tools: {len(tools)}")
    print(f"Endpoints: /infer, /v1/chat/completions, /models, /v1/models, /config")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopping server...")
        server.server_close()

def try_forward_to_server(args, selected_model, tools, messages, system_msg, context_text, full_prompt, image_path, audio_path):
    """Attempts to forward the request to a running gbox server if compatible."""
    if args.no_server or args.server:
        return False

    url = f"http://localhost:{args.port}/config"
    try:
        with urllib.request.urlopen(url, timeout=0.5) as resp:
            config = json.loads(resp.read().decode("utf-8"))
    except (urllib.error.URLError, ConnectionRefusedError):
        return False
    except Exception:
        return False

    # Compatibility check
    if config.get("model") != selected_model:
        return False
    
    server_tools = set(config.get("tools", []))
    required_tools = set(t.__name__ for t in tools)
    if not required_tools.issubset(server_tools):
        # Server is missing some tools we need
        return False

    # If we get here, the server is compatible. Forward the prompt.
    print(f"[Info] Diverting to running server ({selected_model})...", file=sys.stderr)
    
    # Construct the payload
    content_list = []
    if context_text: content_list.append({"type": "text", "text": f"Prior Context:\n{context_text}\n\n---\n"})
    if full_prompt: content_list.append({"type": "text", "text": full_prompt})
    if image_path: content_list.append({"type": "image", "path": os.path.abspath(os.path.expanduser(image_path))})
    if audio_path: content_list.append({"type": "audio", "path": os.path.abspath(os.path.expanduser(audio_path))})

    final_messages = []
    if system_msg:
        final_messages.append({"role": "system", "content": [{"type": "text", "text": system_msg}]})
    final_messages.extend(messages)
    final_messages.append({"role": "user", "content": content_list})

    payload = {
        "model": selected_model,
        "messages": final_messages,
        "stream": args.stream
    }

    try:
        req = urllib.request.Request(
            f"http://localhost:{args.port}/v1/chat/completions",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"}
        )
        
        raw_text = ""
        with urllib.request.urlopen(req) as resp:
            if args.stream:
                for line in resp:
                    line = line.decode("utf-8").strip()
                    if line.startswith("data: "):
                        data_str = line[6:]
                        if data_str == "[DONE]":
                            break
                        chunk = json.loads(data_str)
                        delta = chunk["choices"][0].get("delta", {})
                        if "content" in delta:
                            text_part = delta["content"]
                            raw_text += text_part
                            if not args.json: print(text_part, end="", flush=True)
                if not args.json: print()
            else:
                result = json.loads(resp.read().decode("utf-8"))
                raw_text = result["choices"][0]["message"]["content"]
                if not args.json: print(raw_text)

        final_output = raw_text
        if args.json:
            clean_text = raw_text.strip()
            if clean_text.startswith("```"):
                start, end = clean_text.find("{"), clean_text.rfind("}") + 1
                if start != -1 and end != 0: clean_text = clean_text[start:end]
            try:
                final_output = json.dumps(json.loads(clean_text), indent=2)
            except:
                final_output = json.dumps({"error": "Failed to parse JSON", "raw": raw_text}, indent=2)
            print(final_output)

        if args.clipboard:
            copy_to_clipboard(final_output)

        return True
    except urllib.error.HTTPError as e:
        body = ""
        try:
            body = e.read().decode("utf-8", errors="replace")
            parsed = json.loads(body)
            detail = parsed.get("error") or body
        except Exception:
            detail = body or str(e)
        print(f"[Warning] Server diversion failed ({e.code}): {detail}. Falling back to local Engine.", file=sys.stderr)
        return False
    except Exception as e:
        print(f"[Warning] Server diversion failed: {e}. Falling back to local Engine.", file=sys.stderr)
        return False

def _describe_model_storage():
    """Return a formatted 'Model storage' block for the --help epilog showing
    the search paths (in priority order), whether each exists, and any models
    currently discoverable. Also points users at the LiteRT-LM HuggingFace community."""
    storage_paths = []
    env_path = os.getenv("LITERT_LM_MODELS_DIR")
    if env_path:
        storage_paths.append(("$LITERT_LM_MODELS_DIR", os.path.expanduser(env_path)))
    storage_paths.append(("default", os.path.expanduser("~/.litert-lm/models")))
    storage_paths.append(("default", os.path.expanduser("~/.config/litert-lm/models")))

    lines = ["", "Model storage (search order — first match wins):"]
    for label, path in storage_paths:
        marker = "✓" if os.path.isdir(path) else "·"
        lines.append(f"  {marker} {path}  [{label}]")
    lines.append("  Override the primary location with: export LITERT_LM_MODELS_DIR=/path/to/models")

    try:
        discovered = get_available_models()
    except Exception:
        discovered = []
    if discovered:
        lines.append(f"  Discovered ({len(discovered)}): {', '.join(discovered)}")

    lines.append("  More models: https://huggingface.co/litert-community  (download .litertlm into a search path above)")
    return "\n".join(lines) + "\n"


def _describe_bundled_preset():
    """Inspect the bundled preset.py (next to this script) and return a formatted
    'Available tools' block for the --help epilog. Returns '' if no preset is found
    or it can't be loaded."""
    preset_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "preset.py")
    if not os.path.exists(preset_path):
        return ""
    try:
        spec = importlib.util.spec_from_file_location("_help_preset", preset_path)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
    except Exception:
        return ""
    tool_sets = getattr(module, "tool_sets", {}) or {}
    all_tools = getattr(module, "tools", []) or []
    if not tool_sets and not all_tools:
        return ""
    lines = ["", "Available tools (bundled preset.py — pass --presets preset.py to enable):"]
    if tool_sets:
        lines.append("  Sets:")
        for set_name in sorted(tool_sets.keys()):
            members = tool_sets[set_name]
            names = ", ".join(t.__name__ for t in members)
            lines.append(f"    {set_name:<8} ({len(members)}): {names}")
    if all_tools:
        unique_names = sorted({t.__name__ for t in all_tools})
        lines.append(f"  All ({len(unique_names)}): {', '.join(unique_names)}")
    return "\n".join(lines) + "\n"


def main():
    examples_block = """\
Examples:
  Quick prompt:
    gbox "Explain transformers in two sentences."

  Pipe stdin (text, code, or a PDF) into the prompt:
    cat report.pdf | gbox "Summarize the key findings."
    git diff | gbox "Write a commit message for these changes."

  Multimodal:
    gbox --image screenshot.png "What's in this image?"
    gbox --audio call.wav "Transcribe verbatim."

  Tools (require --presets to point at a preset module; see bundled preset below):
    gbox --presets preset.py --tools mac "Summarize my Finder selection."
    gbox --presets preset.py --tools fs,web "Find local TODOs and open the top GitHub issue."
    gbox --presets preset.py "Run all tools available in the preset."

  Higher-capability model + JSON output + clipboard:
    gbox --high --json -c "Extract entities from: Acme hired Jane in Tokyo."

  Persistent multi-turn session:
    gbox --session brainstorm "Let's plan a launch checklist."
    gbox --session brainstorm "Add a rollback step."

  Fabric system prompt + context:
    gbox --system-file summarize --context project-notes "Summarize."

  Server mode (start once, then requests auto-divert to it):
    gbox --server start
    gbox --server status
    gbox "Now this runs against the warm server."

  Pick a specific model (any of these forms):
    gbox --model gemma-4-E4B-it "Why is the sky blue?"
    gbox --model qwen3-4b "What is gravitronics?"        # shorthand from 'litert-lm import'
    gbox --model ~/.litert-lm/models/my-custom.litertlm "Prompt..."
    gbox gemma-4-E4B-it "Why is the sky blue?"          # positional form also works

  Inspect a model's modalities / format without loading it:
    gbox modelinfo qwen3-4b
"""
    parser = argparse.ArgumentParser(
        description="gbox - Quick inference tool for LiteRT-LM (context window maxes out at 4096 tokens). Server includes /models endpoint.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=examples_block + _describe_model_storage() + _describe_bundled_preset(),
    )
    parser.add_argument("model_or_prompt", nargs="?", help="Model ID, path, or the prompt itself")
    parser.add_argument("prompt_parts", nargs="*", help="Remaining parts of the prompt if first arg was a model")
    parser.add_argument("--default", action="store_true", help="Use gemma-4-E2B-it model (default)")
    parser.add_argument("--high", action="store_true", help="Use gemma-4-E4B-it model")
    parser.add_argument("--model", help="Model name or path (e.g. gemma-4-E4B-it, or any .litertlm file in a search path). See 'Model storage' section below for search order.")
    parser.add_argument("--prompt", help="The user prompt (overrides positional prompt)")
    parser.add_argument("--presets", help="Path to a preset.py module. If omitted but --tools is given, the bundled preset.py next to gbox is used automatically.")
    parser.add_argument("--tools", help="Comma-separated tools or sets to filter the preset down to (e.g. 'mac', 'fs,web'). If --presets is omitted, the bundled preset.py is auto-loaded. See 'Available tools' below.")
    parser.add_argument("--system-file", help="Named Fabric pattern or system file to use as system prompt")
    parser.add_argument("--context", help="Named Fabric context or path to JSONL/Markdown file")
    parser.add_argument("--schema", help="Named Fabric schema or path to a JSON schema file")
    parser.add_argument("--session", help="Named session ID for persistent conversation")
    parser.add_argument("--image", help="Path to an image file for multimodal inference")
    parser.add_argument("--audio", help="Path to an audio file for multimodal inference")
    # Determine default backend based on architecture
    is_apple_silicon = platform.system() == "Darwin" and platform.machine() == "arm64"
    default_backend = "gpu" if is_apple_silicon else "cpu"

    parser.add_argument("--json", action="store_true", help="Output strict JSON")
    parser.add_argument("--stream", action="store_true", help="Stream the response in real-time")
    parser.add_argument("-c", "--clipboard", action="store_true", help="Copy the final result to the macOS clipboard")
    parser.add_argument("--no-server", action="store_true", help="Disable automatic server diversion")
    parser.add_argument("--server", nargs="?", const="start", choices=["start", "stop", "restart", "status", "logs", "config", "models"], help="Server control: start, stop, restart, status, logs, config, models")
    parser.add_argument("--_internal_run", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--port", type=int, default=8955, help="Server port (default: 8955)")
    parser.add_argument("--backend", default=default_backend, choices=["cpu", "gpu"], help=f"Inference backend (default: {default_backend} — gpu on Apple Silicon, cpu elsewhere)")
    parser.add_argument("--vision-backend", default=default_backend, choices=["cpu", "gpu"], help=f"Vision backend (default: {default_backend} — gpu on Apple Silicon, cpu elsewhere)")
    parser.add_argument("--audio-backend", default="cpu", choices=["cpu", "gpu"], help="Audio backend (default: cpu — gpu unsupported upstream, see ISSUES.md)")
    parser.add_argument("--max-tokens", type=int, default=4096, help="Maximum context window size (input + output tokens, max 4096)")
    parser.add_argument("--mtp", action=argparse.BooleanOptionalAction, default=None, help="Multi-Token Prediction / speculative decoding. Default: OFF on Apple Silicon Metal (measured ~50%% slower on E4B+gpu, see ISSUES.md); ON for non-Darwin GPU per upstream guidance; OFF for cpu. Override with --mtp / --no-mtp.")
    parser.add_argument("--upgrade", action="store_true", help="Upgrade litert-lm via 'uv tool upgrade litert-lm'")
    try:
        _litert_version = importlib.metadata.version("litert-lm")
    except importlib.metadata.PackageNotFoundError:
        _litert_version = "unknown"
    parser.add_argument("--version", action="version", version=f"gbox {__version__} (litert-lm {_litert_version})")
    args = parser.parse_args()

    # modelinfo subcommand: `gbox modelinfo <model>` — inspect a bundle's
    # modalities, format, and MTP draft head without loading it for inference.
    if args.model_or_prompt == "modelinfo":
        target = args.prompt_parts[0] if args.prompt_parts else args.model
        if not target:
            print("Usage: gbox modelinfo <model-id-or-path>", file=sys.stderr)
            sys.exit(2)
        sys.exit(print_model_info(target))

    # Upgrade litert-lm in the venv gbox actually runs in, and exit
    if args.upgrade:
        import subprocess
        print(f"Upgrading litert-lm in {sys.executable}...")
        try:
            result = subprocess.run(
                ["uv", "pip", "install", "--python", sys.executable, "--upgrade", "litert-lm"],
                check=False,
            )
            sys.exit(result.returncode)
        except FileNotFoundError:
            result = subprocess.run(
                [sys.executable, "-m", "pip", "install", "--upgrade", "litert-lm"],
                check=False,
            )
            sys.exit(result.returncode)

    # Server control logic
    if args.server and not args._internal_run:
        import subprocess
        import time as _time
        server_dir = os.path.expanduser("~/.gbox")
        pid_file = os.path.join(server_dir, "server.pid")
        log_file = os.path.join(server_dir, "server.log")

        def _probe_server_state(port):
            """Unified view of server state across pid file, port binding, and HTTP /config.
            Returns dict with: pid_file_pid, pid_file_alive, port_pid, port_cmdline,
            is_gbox_on_port, config_responds."""
            state = {
                "pid_file_pid": None,
                "pid_file_alive": False,
                "port_pid": None,
                "port_cmdline": "",
                "is_gbox_on_port": False,
                "config_responds": False,
            }
            if os.path.exists(pid_file):
                try:
                    with open(pid_file, "r") as f:
                        state["pid_file_pid"] = int(f.read().strip())
                    os.kill(state["pid_file_pid"], 0)
                    state["pid_file_alive"] = True
                except (ProcessLookupError, ValueError, PermissionError):
                    pass
            try:
                r = subprocess.run(
                    ["lsof", "-iTCP:" + str(port), "-sTCP:LISTEN", "-P", "-n", "-t"],
                    capture_output=True, text=True, timeout=2,
                )
                pids = [int(p) for p in r.stdout.split() if p.strip().isdigit()]
                if pids:
                    state["port_pid"] = pids[0]
                    r2 = subprocess.run(
                        ["ps", "-p", str(state["port_pid"]), "-o", "command="],
                        capture_output=True, text=True, timeout=2,
                    )
                    state["port_cmdline"] = r2.stdout.strip()
                    state["is_gbox_on_port"] = "gbox" in state["port_cmdline"].lower()
            except (FileNotFoundError, subprocess.TimeoutExpired):
                pass
            try:
                with urllib.request.urlopen(f"http://localhost:{port}/config", timeout=0.5) as resp:
                    resp.read()
                state["config_responds"] = True
            except Exception:
                pass
            return state

        def _heal_pid_file(state):
            """Reconcile pid file with reality if a gbox server is on the port."""
            if state["is_gbox_on_port"] and state["pid_file_pid"] != state["port_pid"]:
                os.makedirs(server_dir, exist_ok=True)
                with open(pid_file, "w") as f:
                    f.write(str(state["port_pid"]))

        def _do_stop(state):
            """Returns (stopped_pid_or_None, message)."""
            target = state["port_pid"] if state["is_gbox_on_port"] else (state["pid_file_pid"] if state["pid_file_alive"] else None)
            if target is None:
                if os.path.exists(pid_file):
                    os.remove(pid_file)
                return None, "Server is not running."
            try:
                os.kill(target, 15)
            except ProcessLookupError:
                pass
            if os.path.exists(pid_file):
                os.remove(pid_file)
            return target, f"Stopped server (PID: {target})."

        def _wait_for_port_free(port, timeout=8.0):
            deadline = _time.time() + timeout
            while _time.time() < deadline:
                if _probe_server_state(port)["port_pid"] is None:
                    return True
                _time.sleep(0.2)
            return False

        def _spawn_daemon():
            os.makedirs(server_dir, exist_ok=True)
            cmd = [sys.executable, os.path.abspath(__file__)]
            new_args = sys.argv[1:]
            if "--server" not in new_args:
                new_args.extend(["--server", "start"])
            # Drop bare 'restart' if present — daemon should see 'start'
            new_args = ["start" if a == "restart" else a for a in new_args]
            new_args.append("--_internal_run")
            with open(log_file, "a") as log:
                log.write(f"\n--- Server Starting at {datetime.datetime.now()} ---\n")
                subprocess.Popen(cmd + new_args, stdout=log, stderr=log, start_new_session=True)
            print(f"Server started in background. Logs: {log_file}")

        if args.server == "status":
            state = _probe_server_state(args.port)
            _heal_pid_file(state)
            if state["config_responds"] and state["is_gbox_on_port"]:
                print(f"Server is running on port {args.port} (PID: {state['port_pid']}).")
                sys.exit(0)
            if state["port_pid"] and not state["is_gbox_on_port"]:
                print(f"Server is NOT running on port {args.port}.")
                print(f"  Port held by non-gbox process: PID {state['port_pid']} ({state['port_cmdline']})", file=sys.stderr)
                sys.exit(1)
            if state["pid_file_alive"]:
                print(f"Server in inconsistent state: pid file says PID {state['pid_file_pid']} alive, but nothing on port {args.port}.", file=sys.stderr)
                sys.exit(1)
            if state["pid_file_pid"]:
                print("Server is NOT running (stale PID file removed).")
                if os.path.exists(pid_file):
                    os.remove(pid_file)
                sys.exit(1)
            print(f"Server is NOT running on port {args.port}.")
            sys.exit(1)

        elif args.server == "stop":
            state = _probe_server_state(args.port)
            _, msg = _do_stop(state)
            print(msg)
            sys.exit(0)

        elif args.server == "logs":
            if os.path.exists(log_file):
                with open(log_file, "r") as f:
                    print(f.read())
                sys.exit(0)
            print("No log file found.")
            sys.exit(1)

        elif args.server in ("config", "models"):
            url = f"http://localhost:{args.port}/{args.server}"
            try:
                with urllib.request.urlopen(url, timeout=2.0) as resp:
                    body = resp.read().decode("utf-8")
            except (urllib.error.URLError, ConnectionRefusedError) as e:
                print(f"Server is NOT reachable on port {args.port}: {e}", file=sys.stderr)
                sys.exit(1)
            try:
                print(json.dumps(json.loads(body), indent=2))
            except ValueError:
                print(body)
            sys.exit(0)

        elif args.server in ("start", "restart"):
            state = _probe_server_state(args.port)
            _heal_pid_file(state)

            if args.server == "restart":
                stopped, msg = _do_stop(state)
                print(msg)
                if stopped is not None and not _wait_for_port_free(args.port):
                    print(f"Warning: port {args.port} still held after stop — start may fail.", file=sys.stderr)
                state = _probe_server_state(args.port)

            # Already-running gbox on the port → no-op
            if state["config_responds"] and state["is_gbox_on_port"]:
                print(f"Server already running on port {args.port} (PID: {state['port_pid']}). Use --server restart to recycle.")
                sys.exit(0)
            # Non-gbox process on the port → refuse, do not steal the port
            if state["port_pid"] and not state["is_gbox_on_port"]:
                print(f"Error: Port {args.port} is in use by non-gbox PID {state['port_pid']} ({state['port_cmdline']}). Refusing to start.", file=sys.stderr)
                print(f"  Inspect: lsof -iTCP:{args.port} -sTCP:LISTEN -P -n", file=sys.stderr)
                sys.exit(1)
            # Pid file says alive but port empty → ambiguous, refuse
            if state["pid_file_alive"] and not state["port_pid"]:
                print(f"Error: pid file claims PID {state['pid_file_pid']} alive but nothing on port {args.port}. Resolve manually with --server stop.", file=sys.stderr)
                sys.exit(1)
            # Stale pid file → clean
            if state["pid_file_pid"] and not state["pid_file_alive"] and os.path.exists(pid_file):
                os.remove(pid_file)

            _spawn_daemon()
            sys.exit(0)

    # Model and Prompt Resolution Logic
    selected_model = "gemma-4-E2B-it" # Default
    positional_prompt = ""

    if args.model_or_prompt:
        # If --model was given, the positional is always prompt (no model probe).
        if args.model:
            positional_prompt = " ".join([args.model_or_prompt] + args.prompt_parts)
        else:
            resolved = resolve_model_path(args.model_or_prompt)
            if os.path.exists(resolved) or args.model_or_prompt in ["gemma-4-E2B-it", "gemma-4-E4B-it"]:
                selected_model = args.model_or_prompt
                if args.prompt_parts:
                    positional_prompt = " ".join(args.prompt_parts)
            else:
                positional_prompt = " ".join([args.model_or_prompt] + args.prompt_parts)

    # Precedence: --high > --default > --model > positional model arg
    if args.model:
        selected_model = args.model
    if args.default:
        selected_model = "gemma-4-E2B-it"
    if args.high:
        selected_model = "gemma-4-E4B-it"

    is_high_requested = (selected_model == "gemma-4-E4B-it") or args.high
    litert_lm.set_min_log_severity(litert_lm.LogSeverity.ERROR)

    # Load presets — auto-resolve bundled preset.py when --tools is given without --presets
    tools, system_msg = ([], "")
    if args.tools and not args.presets:
        bundled_preset = os.path.join(os.path.dirname(os.path.abspath(__file__)), "preset.py")
        if os.path.exists(bundled_preset):
            args.presets = bundled_preset
            print(f"[info] --tools given without --presets; using bundled preset: {bundled_preset}", file=sys.stderr)
        else:
            print(f"Warning: --tools '{args.tools}' ignored — no --presets given and bundled preset.py not found at {bundled_preset}", file=sys.stderr)
    if args.presets:
        tools, system_msg = load_preset(args.presets, args.tools)
        active_tool_names = {t.__name__ for t in tools}
        high_tools_in_use = active_tool_names.intersection(HIGH_COGNITION_TOOLS)
        if high_tools_in_use and not is_high_requested and selected_model == "gemma-4-E2B-it":
            tools_str = ", ".join(high_tools_in_use)
            print(f"[Recommendation] Using high-cognition tools ({tools_str}).", file=sys.stderr)
            print(f"Consider adding '--high' (gemma-4-E4B-it) for better reasoning.", file=sys.stderr)

    # System File / Fabric Pattern resolution
    if args.system_file:
        system_file_path = resolve_fabric_resource("system-file", args.system_file)
        if system_file_path:
            with open(system_file_path, "r") as f:
                system_msg = f.read().strip()
        else:
            print(f"Warning: System file '{args.system_file}' not found in Fabric patterns.", file=sys.stderr)

    # Context Resolution
    messages = []
    context_text = ""
    resolved_context_path = resolve_fabric_resource("context", args.context) if args.context else None
    context_file = resolved_context_path or args.context

    if context_file:
        try:
            with open(context_file, "r") as f:
                content = f.read()
                try:
                    parsed = json.loads(content)
                    if isinstance(parsed, list):
                        messages.extend(parsed)
                    else:
                        messages.extend([json.loads(line) for line in content.strip().split("\n") if line.strip()])
                except json.JSONDecodeError:
                    context_text = content.strip()
        except Exception as e:
            print(f"Error loading context: {e}", file=sys.stderr)

    # Session Management
    session_path = None
    if args.session:
        session_path = resolve_fabric_resource("session", args.session)
        if os.path.exists(session_path):
            try:
                with open(session_path, "r") as f:
                    session_msgs = json.load(f)
                    if isinstance(session_msgs, list):
                        messages.extend(session_msgs)
            except Exception as e:
                print(f"Error loading session: {e}", file=sys.stderr)
        
        # Pre-emptive summarization if needed
        messages = manage_session_window(messages, limit=args.max_tokens - 1000)

    # Stdin
    stdin_content = b""
    if not args.server and not sys.stdin.isatty():
        try:
            stdin_content = sys.stdin.buffer.read()
        except OSError:
            pass

    extracted_text = ""
    pdf_image = None
    if stdin_content.startswith(b"%PDF"):
        extracted_text, pdf_image = process_pdf(stdin_content)
    else:
        try:
            extracted_text = stdin_content.decode("utf-8").strip()
        except UnicodeDecodeError:
            pass

    # Prompt assembly
    primary_prompt = ""
    if args.prompt:
        expanded_path = os.path.expanduser(args.prompt)
        if os.path.isfile(expanded_path):
            with open(expanded_path, "r") as f: primary_prompt = f.read().strip()
        else: primary_prompt = args.prompt
    else:
        primary_prompt = positional_prompt
    
    full_prompt = primary_prompt
    if extracted_text:
        full_prompt = f"{full_prompt}\n\nContext from input:\n{extracted_text}" if full_prompt else extracted_text

    image_path = args.image or pdf_image
    audio_path = args.audio
    if not full_prompt:
        if image_path: full_prompt = "Describe this image."
        elif audio_path: full_prompt = "Describe this audio."

    if not full_prompt and not image_path and not audio_path and not messages and not args.server:
        print("Error: No input provided.", file=sys.stderr)
        sys.exit(1)

    # Schema resolution
    schema_content = None
    if args.schema:
        resolved_schema_path = resolve_fabric_resource("schema", args.schema)
        schema_file = resolved_schema_path or args.schema
        try:
            with open(schema_file, "r") as f:
                schema_content = f.read().strip()
                json.loads(schema_content)
        except Exception as e:
            print(f"Error loading schema: {e}", file=sys.stderr)
            sys.exit(1)

    if schema_content:
        schema_instruction = (
            f"\n\nYou MUST provide your response as a single JSON object matching this schema:\n{schema_content}\n"
            "Do not include any conversational filler, markdown formatting (like ```json), or explanation outside the JSON object."
        )
        system_msg = (system_msg or "You are a helpful assistant.") + schema_instruction

    if try_forward_to_server(args, selected_model, tools, messages, system_msg, context_text, full_prompt, image_path, audio_path):
        return

    # Inference
    model_path = resolve_model_path(selected_model)
    # A text-only bundle (e.g. an imported Qwen3) has no vision/audio encoder;
    # wiring one up makes LiteRT-LM raise NOT_FOUND at conversation creation, so
    # only enable backends the bundle actually carries.
    caps = detect_model_capabilities(model_path)
    backend = litert_lm.Backend.GPU if args.backend == "gpu" else litert_lm.Backend.CPU
    v_backend = (litert_lm.Backend.GPU if args.vision_backend == "gpu" else litert_lm.Backend.CPU) if caps["vision"] else None
    a_backend = (litert_lm.Backend.GPU if args.audio_backend == "gpu" else litert_lm.Backend.CPU) if caps["audio"] else None
    if not (caps["vision"] and caps["audio"]):
        only = "+".join(["text"] + (["vision"] if caps["vision"] else []) + (["audio"] if caps["audio"] else []))
        print(f"[info] '{selected_model}' is {only}-only; skipping absent encoder backend(s).", file=sys.stderr)

    # MTP (speculative decoding) default resolution:
    #   --mtp / --no-mtp explicit  → honored
    #   Darwin (Apple Silicon Metal) → OFF (benchmarked ~50% slower on E4B, see ISSUES.md)
    #   Other GPU                    → ON  (matches upstream "universally recommended on GPU")
    #   CPU                          → OFF
    if args.mtp is not None:
        mtp_enabled = args.mtp
    elif args.backend == "gpu" and platform.system() != "Darwin":
        mtp_enabled = True
    else:
        mtp_enabled = False
    # MTP needs a draft head bundled in the .litertlm; enabling it without one
    # fails Engine init. Force off for bundles that lack the drafter, even if the
    # user passed --mtp (third-party models like Qwen3 have no draft head).
    if mtp_enabled and not caps["mtp"]:
        mtp_enabled = False
        if args.mtp:
            print(f"[info] '{selected_model}' has no MTP draft head; ignoring --mtp.", file=sys.stderr)
    args._mtp_resolved = mtp_enabled

    try:
        with suppress_stderr():
            engine = litert_lm.Engine(
                model_path=model_path,
                backend=backend,
                vision_backend=v_backend,
                audio_backend=a_backend,
                max_num_tokens=args.max_tokens,
                cache_dir=os.path.dirname(model_path),
                enable_speculative_decoding=mtp_enabled,
            )
        
        if args.server:
            run_server(args, engine, selected_model, tools, system_msg)
            return

        final_messages = []
        if system_msg:
            final_messages.append({"role": "system", "content": [{"type": "text", "text": system_msg}]})
        final_messages.extend(messages)

        with engine.create_conversation(tools=tools, messages=final_messages) as conv:
            content_list = []
            if context_text: content_list.append({"type": "text", "text": f"Prior Context:\n{context_text}\n\n---\n"})
            if full_prompt: content_list.append({"type": "text", "text": full_prompt})
            if image_path: content_list.append({"type": "image", "path": os.path.abspath(os.path.expanduser(image_path))})
            if audio_path: content_list.append({"type": "audio", "path": os.path.abspath(os.path.expanduser(audio_path))})

            message_obj = {"role": "user", "content": content_list}
            raw_text = ""

            if args.stream:
                stream = conv.send_message_async(message_obj)
                for chunk in stream:
                    for item in chunk.get("content", []):
                        if item.get("type") == "text":
                            text_part = item["text"]
                            raw_text += text_part
                            if not args.json: print(text_part, end="", flush=True)
                if not args.json: print()
            else:
                response = conv.send_message(message_obj)
                raw_text = "".join([part.get("text", "") for part in response.get("content", []) if part.get("type") == "text"])
                if not args.json: print(raw_text)

            # Cleanup
            if pdf_image and os.path.exists(pdf_image): os.remove(pdf_image)

            # Session Persistence
            if session_path:
                os.makedirs(os.path.dirname(session_path), exist_ok=True)
                messages.append(message_obj)
                messages.append({"role": "assistant", "content": [{"type": "text", "text": raw_text}]})
                with open(session_path, "w") as f:
                    json.dump(messages, f, indent=2)

            final_output = raw_text
            if args.json:
                clean_text = raw_text.strip()
                if clean_text.startswith("```"):
                    start, end = clean_text.find("{"), clean_text.rfind("}") + 1
                    if start != -1 and end != 0: clean_text = clean_text[start:end]
                try:
                    final_output = json.dumps(json.loads(clean_text), indent=2)
                except:
                    final_output = json.dumps({"error": "Failed to parse JSON", "raw": raw_text}, indent=2)
                print(final_output)

            if args.clipboard:
                copy_to_clipboard(final_output)

    except Exception as e:
        print(f"Runtime Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
