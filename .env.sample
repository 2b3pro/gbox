# gbox environment variables
# -----------------------------------------------------------------------------
# Copy to .env and edit. gbox does NOT auto-load .env — export these in your
# shell, source the file (`set -a; source .env; set +a`), or wire them into
# your launcher of choice. .env is gitignored.
# -----------------------------------------------------------------------------

# --- Model storage ----------------------------------------------------------
# Primary search path for .litertlm models. Takes priority over the two
# default locations (~/.litert-lm/models, ~/.config/litert-lm/models).
# Browse / download more models at https://huggingface.co/litert-community
#LITERT_LM_MODELS_DIR=/path/to/your/litertlm/models

# --- Fabric resource roots --------------------------------------------------
# Where gbox looks up --system-file, --context, --schema, and --session names.
# Defaults to ~/.config/fabric (with subdirs: patterns/, contexts/, schemas/,
# sessions/). Override only if your Fabric install lives elsewhere.
#FABRIC_DIR=/Users/you/.config/fabric

# --- Log suppression (advanced) ---------------------------------------------
# gbox sets these to silence LiteRT-LM / WebGPU / TensorFlow init noise.
# Raise the level if you want to debug Metal delegate output. Lower = noisier.
#GLOG_minloglevel=2
#LITERT_LOG_LEVEL=2
#TF_CPP_MIN_LOG_LEVEL=3
