#!/bin/bash
# wtd — what is this directory?, powered by gbox (LiteRT-LM on-device)
# Install globally as `gbox-wtd`: see demo/README.md "Install demos globally (optional)"
#
# Usage:  wtd              # current directory
#         wtd ~/projects   # any directory
#         wtd -c           # copy summary to clipboard
#
# Requires: gbox installed (https://github.com/2b3pro/gbox)

COPY=false
TARGET="."

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
SYSTEM_FILE="$SCRIPT_DIR/systems/wtd.md"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--copy) COPY=true; shift ;;
        -h|--help)
            echo "wtd — what is this directory?"
            echo ""
            echo "Usage: wtd [OPTIONS] [directory]"
            echo ""
            echo "  -c, --copy  Copy summary to clipboard"
            echo "  -h, --help  Show this help"
            echo ""
            echo "Examples:"
            echo "  wtd                     # current directory"
            echo "  wtd ~/some/project      # any directory"
            echo "  wtd -c .                # copy summary to clipboard"
            echo ""
            echo "Requires: gbox (LiteRT-LM on-device CLI)"
            exit 0
            ;;
        -*) echo "Unknown option: $1. Use --help."; exit 1 ;;
        *)  TARGET="$1"; shift ;;
    esac
done

if [[ ! -d "$TARGET" ]]; then
    echo "Error: '$TARGET' is not a directory" >&2
    exit 1
fi

if ! command -v gbox &>/dev/null; then
    echo "Error: gbox not found. Install from https://github.com/2b3pro/gbox" >&2
    exit 1
fi

# Gather directory info (kept small for the 4096-token context window)
snapshot=""
snapshot+="Directory: $(cd "$TARGET" && pwd)
"
snapshot+="$(ls -la "$TARGET" 2>/dev/null | head -30)
"

for f in README.md README readme.md Package.swift package.json Cargo.toml go.mod pyproject.toml Makefile Dockerfile docker-compose.yml .gitignore; do
    if [[ -f "$TARGET/$f" ]]; then
        snippet=$(head -5 "$TARGET/$f" 2>/dev/null)
        snapshot+="
--- $f (first 5 lines) ---
$snippet
"
    fi
done

if [[ -d "$TARGET/.git" ]] || git -C "$TARGET" rev-parse --git-dir &>/dev/null 2>&1; then
    branch=$(git -C "$TARGET" branch --show-current 2>/dev/null)
    last_commit=$(git -C "$TARGET" log --oneline -1 2>/dev/null)
    snapshot+="
--- git ---
branch: $branch
last commit: $last_commit
"
fi

result=$(echo "$snapshot" | gbox --system-file "$SYSTEM_FILE")
status=$?

if [[ $status -ne 0 ]]; then
    echo "Error: gbox failed (exit $status)" >&2
    exit $status
fi

if $COPY; then
    echo "$result" | pbcopy
    echo -e "\033[90m(copied to clipboard)\033[0m"
fi

echo "$result"
