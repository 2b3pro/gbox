#!/bin/bash
# naming — name things well, powered by gbox (LiteRT-LM on-device)
# Install globally as `gbox-naming`: see demo/README.md "Install demos globally (optional)"
#
# Usage:  naming "function that retries HTTP requests with backoff"
#         naming "variable for the number of failed logins"
#         naming -c "config file for database migrations"   # copy to clipboard
#
# Requires: gbox installed (https://github.com/2b3pro/gbox)

COPY=false

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
SYSTEM_FILE="$SCRIPT_DIR/systems/naming.md"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--copy) COPY=true; shift ;;
        -h|--help)
            echo "naming — name things well"
            echo ""
            echo "Usage: naming [OPTIONS] \"what it does\""
            echo ""
            echo "  -c, --copy  Copy suggestions to clipboard"
            echo "  -h, --help  Show this help"
            echo ""
            echo "Examples:"
            echo "  naming \"function that retries HTTP requests with backoff\""
            echo "  naming \"variable for the count of failed login attempts\""
            echo "  naming \"class that manages WebSocket connections\""
            echo "  naming \"file containing database migration scripts\""
            echo ""
            echo "Requires: gbox (LiteRT-LM on-device CLI)"
            exit 0
            ;;
        -*) echo "Unknown option: $1. Use --help."; exit 1 ;;
        *)  break ;;
    esac
done

if [[ -z "$1" ]]; then
    echo "Usage: naming \"describe what it does\""
    echo "       naming --help for more options"
    exit 1
fi

if ! command -v gbox &>/dev/null; then
    echo "Error: gbox not found. Install from https://github.com/2b3pro/gbox" >&2
    exit 1
fi

result=$(gbox --system-file "$SYSTEM_FILE" "$1")
status=$?

if [[ $status -ne 0 ]]; then
    echo "Error: gbox failed (exit $status)" >&2
    exit $status
fi

if $COPY; then
    echo "$result" | pbcopy
    echo -e "\033[90m(copied to clipboard)\033[0m"
fi

echo "$result"
